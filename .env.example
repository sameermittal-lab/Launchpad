# LaunchPad Environment Configuration
# Copy to .env and customize

# Server
LAUNCHPAD_HOST=0.0.0.0
LAUNCHPAD_PORT=7070

# Data storage
LAUNCHPAD_DATA_DIR=./users
LAUNCHPAD_DB_PATH=./launchpad.db

# Logging
LAUNCHPAD_LOG_LEVEL=INFO

# Max profiles per instance
LAUNCHPAD_MAX_PROFILES=3

# LLM API keys are stored per-profile in the database (encrypted)
# No need to put them here unless you want global defaults

# Optional: Gmail OAuth (used as fallback if user hasn't uploaded their own)
# Get from https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
